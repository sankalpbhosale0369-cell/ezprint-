{
    email {$ACME_EMAIL}
}

{$API_DOMAIN} {
    encode zstd gzip

    @ws {
        path /ws/*
    }

    reverse_proxy @ws api:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    reverse_proxy api:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }
}

{$S3_DOMAIN} {
    encode zstd gzip

    # MinIO S3 API - must be reachable from browsers because
    # customer uploads and agent downloads use presigned URLs.
    reverse_proxy minio:9000 {
        header_up Host {host}
    }
}
