# ---------- EzPrint Backend ----------
ENV=dev
LOG_LEVEL=INFO
# Comma-separated list. Use "*" only in dev.
CORS_ALLOW_ORIGINS=*
# Public base URL of the API, used in presigned links/QR codes.
PUBLIC_BASE_URL=http://localhost:8000

# ---------- Auth ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-please-super-long-secret
JWT_ALG=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7
AGENT_SESSION_TTL_HOURS=24
UPLOAD_TOKEN_TTL_MINUTES=30

# ---------- Database ----------
POSTGRES_USER=ezprint
POSTGRES_PASSWORD=ezprint_dev_password
POSTGRES_DB=ezprint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://ezprint:ezprint_dev_password@postgres:5432/ezprint

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- MinIO / S3 ----------
# Internal endpoint used by the backend (inside docker network).
S3_ENDPOINT=http://minio:9000
# Public endpoint exposed to customers/agents for presigned URLs (must be reachable from browsers).
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio_ezprint
S3_SECRET_KEY=minio_ezprint_dev_password
S3_BUCKET_NAME=ezprint
S3_REGION=us-east-1
# MinIO root credentials (used only by minio + minio-init services)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_password

# ---------- Caddy / Domains (prod only) ----------
API_DOMAIN=api.example.com
S3_DOMAIN=s3.example.com
ACME_EMAIL=ops@example.com
