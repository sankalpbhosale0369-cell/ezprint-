# EzPrint desktop agent environment configuration
#
# Copy this file to `.env` and fill in values. Only variables the Windows
# agent (shopkeeper_app) reads live here. Backend-side settings
# (Postgres, Redis, MinIO, JWT secrets) live in ezprint-backend/.env —
# see ezprint-backend/.env.example.

# =============================================================================
# BACKEND TARGET (required)
# =============================================================================
# FastAPI base URL. In dev point this at the local docker-compose stack;
# in production use the public HTTPS endpoint.
EZPRINT_API_BASE_URL=http://localhost:8000

# WebSocket URL. Leave unset to derive from EZPRINT_API_BASE_URL
# (http → ws, https → wss). Override only to talk to a different host.
# EZPRINT_WS_URL=ws://localhost:8000/ws/agent

# =============================================================================
# LICENSING (future)
# =============================================================================
# Disabled by default until the licensing service is shipped.
EZPRINT_LICENSE_ENABLED=false

# =============================================================================
# LOCAL CACHE (shrinking legacy — do not add new writers)
# =============================================================================
# The agent keeps a small SQLite cache for historical job views. Once
# shopkeeper_app/dashboard.py is fully migrated, this will be removed.
DATABASE_URL=sqlite:///ezprint.db

# =============================================================================
# FILE HANDLING (local preview + n-up PDF)
# =============================================================================
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,doc,ppt,pptx,png,jpg,jpeg,gif,bmp,tiff

# =============================================================================
# PRINTING
# =============================================================================
PRINT_CONFIRMATION_TIMEOUT_SECS=180
SEND_RETRY_ATTEMPTS=3
SEND_RETRY_BASE_DELAY_SECS=1
NETWORK_SCAN_MAX_IP=50
NETWORK_SCAN_MAX_THREADS=20

# Ghostscript executable (optional — required for some IPP/LPR paths)
# Windows: C:\Program Files\gs\gs10.02.0\bin\gswin64c.exe
# Linux:   /usr/bin/gs
GHOSTSCRIPT_EXE=

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# =============================================================================
# AUTO-UPDATE CHANNEL
# =============================================================================
UPDATE_CHECK_URL=https://api.ezprint.com/agent/version
UPDATE_DOWNLOAD_URL=https://api.ezprint.com/agent/download
UPDATE_CHANNEL=stable                # stable | beta | dev
AUTO_UPDATE_ENABLED=true
# Optional bearer token for authenticated update channels
SHOP_API_TOKEN=
