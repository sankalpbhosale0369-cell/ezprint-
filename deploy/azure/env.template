ENV=prod
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=*

# ============================================================
# SET THESE TWO VALUES — everything else is pre-configured
API_DOMAIN=CHANGEME.eastus.cloudapp.azure.com
ACME_EMAIL=your@email.com
# ============================================================

PUBLIC_BASE_URL=https://CHANGEME.eastus.cloudapp.azure.com

# Auth
JWT_SECRET=__JWT_SECRET__
JWT_ALG=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7
AGENT_SESSION_TTL_HOURS=24
UPLOAD_TOKEN_TTL_MINUTES=30

# Database
POSTGRES_USER=ezprint
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=ezprint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://ezprint:__PGPASS_IN_URL__@postgres:5432/ezprint

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
# S3_ENDPOINT is the internal docker-network address (never changes).
# S3_PUBLIC_ENDPOINT is what gets embedded in presigned URLs sent to
# browsers and the desktop agent — must be publicly reachable.
# With the azure single-host setup, MinIO is served under /s3/* on the
# same hostname as the API, so no separate subdomain is needed.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://CHANGEME.eastus.cloudapp.azure.com/s3
S3_ACCESS_KEY=minio_ezprint
S3_SECRET_KEY=__S3_SECRET_KEY__
S3_BUCKET_NAME=ezprint
S3_REGION=us-east-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__

# Caddy / Domains
# API_DOMAIN is used by both the prod overlay and Caddyfile.azure.
# S3_DOMAIN is not needed with the single-host azure setup (leave blank).
S3_DOMAIN=
